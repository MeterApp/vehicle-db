{
  "name": "nhtsa-offline",
  "version": "1.0.0",
  "description": "Offline NHTSA vehicle makes/models database bundled as SQLite",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "data/nhtsa.db"
  ],
  "scripts": {
    "build:db": "tsx scripts/build-db.ts",
    "build:ts": "tsc",
    "build": "npm run build:ts",
    "prepublishOnly": "npm run build",
    "test": "vitest run"
  },
  "keywords": [
    "nhtsa",
    "vehicles",
